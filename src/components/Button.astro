---
interface Props {
  href: string;
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  shadow?: 'none' | 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, size = 'md', fullWidth = false, shadow = 'md', class: className = '' } = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'text-sm px-5 py-2.5',
  md: 'px-6 py-3.5',
  lg: 'px-8 py-4',
};

const shadowClasses: Record<string, string> = {
  none: '',
  sm: 'shadow-sm hover:shadow-md',
  md: 'shadow-md hover:shadow-lg',
  lg: 'shadow-lg hover:shadow-xl',
};
---

<a
  href={href}
  class:list={[
    'inline-flex items-center gap-2 bg-sage-700 text-white font-body font-semibold rounded-full hover:bg-sage-800 transition-all duration-300 hover:-translate-y-0.5',
    sizeClasses[size],
    shadowClasses[shadow],
    fullWidth && 'justify-center w-full',
    className,
  ]}
>
  <slot />
</a>
