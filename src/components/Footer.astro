---
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-warm-800 text-warm-200 mt-auto">
  <div class="max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">

      <!-- Colonne 1 : Identité -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src={`${base}logo.svg`} alt="Logo Espace Satya" class="h-10 w-auto brightness-0 invert opacity-80" />
          <div>
            <span class="font-heading text-xl font-semibold text-warm-50 block">Espace Satya</span>
            <span class="font-body text-xs text-warm-400 block mt-0.5">Cabinet pluridisciplinaire</span>
          </div>
        </div>
        <p class="font-body text-sm text-warm-400 leading-relaxed">
          Un espace dédié à votre bien-être, réunissant des praticiennes aux approches complémentaires pour un accompagnement global et bienveillant.
        </p>
      </div>

      <!-- Colonne 2 : Liens rapides -->
      <div>
        <h3 class="font-heading text-lg font-semibold text-warm-100 mb-4">Navigation</h3>
        <ul class="space-y-2" role="list">
          {[
            { href: `${base}`, label: 'Accueil' },
            { href: `${base}praticiens/`, label: 'Nos praticien·ne·s' },
            { href: `${base}salle/`, label: 'L\'Espace Ananda' },
            { href: `${base}contact/`, label: 'Contact & accès' },
          ].map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-warm-400 hover:text-sage-300 transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Colonne 3 : Coordonnées -->
      <div>
        <h3 class="font-heading text-lg font-semibold text-warm-100 mb-4">Nous trouver</h3>
        <address class="not-italic space-y-3">
          <div class="flex items-start gap-3">
            <Icon name="location" class="w-4 h-4 mt-0.5 text-sage-400 shrink-0" strokeWidth={1.5} />
            <p class="font-body text-sm text-warm-400 leading-relaxed">
              17 boulevard des Évadés de France<br />
              1er étage – Épicentre<br />
              66200 Elne
            </p>
          </div>
          <div class="flex items-center gap-3">
            <Icon name="email" class="w-4 h-4 text-sage-400 shrink-0" strokeWidth={1.5} />
            <a href="mailto:contact@espacesatya.fr" class="font-body text-sm text-warm-400 hover:text-sage-300 transition-colors">
              contact@espacesatya.fr
            </a>
          </div>
        </address>
      </div>
    </div>

    <!-- Ligne de bas -->
    <div class="border-t border-warm-700 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-warm-500">
        © {currentYear} Espace Satya – Tous droits réservés
      </p>
      <div class="flex items-center gap-4">
        <a href={`${base}mentions-legales/`} class="font-body text-xs text-warm-500 hover:text-warm-300 transition-colors">
          Mentions légales
        </a>
        <span class="text-warm-700" aria-hidden="true">·</span>
        <p class="font-body text-xs text-warm-500">
          Elne, Pyrénées-Orientales (66)
        </p>
      </div>
    </div>
  </div>
</footer>
