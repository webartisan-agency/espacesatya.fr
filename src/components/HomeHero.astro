---
import { Image } from 'astro:assets';
import heroImg from '../assets/photos/hero.jpg';
import { Icon } from 'astro-icon/components';
import Button from './Button.astro';

const base = import.meta.env.BASE_URL;
---

<section class="relative bg-warm-50 overflow-hidden">
  <!-- Subtle decorative circles (background accents) -->
  <div class="absolute top-12 left-8 w-64 h-64 bg-sage-100/40 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-1/3 w-48 h-48 bg-terra-100/30 rounded-full blur-2xl" aria-hidden="true"></div>
  <div class="absolute -top-8 right-1/4 w-36 h-36 bg-sage-50/60 rounded-full blur-2xl hidden lg:block" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-20 lg:py-0 lg:min-h-[65vh] flex items-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">

      <!-- Left: Text Content -->
      <div class="order-1 max-w-xl">
        <!-- Accent welcome -->
        <p class="font-accent text-terra-500 text-2xl md:text-3xl mb-2 tracking-wide">
          Bienvenue à l'
        </p>

        <!-- Main title -->
        <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold text-warm-900 leading-tight mb-4">
          Espace <span class="text-sage-700 italic">Satya</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-sage-700 font-body font-light tracking-wide mb-6">
          Cabinet pluridisciplinaire de bien-être
        </p>

        <!-- Decorative divider -->
        <div class="flex items-center gap-3 mb-6" aria-hidden="true">
          <div class="h-px w-12 bg-terra-300"></div>
          <div class="w-2 h-2 rounded-full bg-terra-400"></div>
          <div class="h-px w-12 bg-terra-300"></div>
        </div>

        <!-- Location -->
        <div class="flex items-center gap-2 text-warm-600 mb-10">
          <Icon name="heroicons:map-pin" class="w-4 h-4 text-terra-500 shrink-0" />
          <span class="text-sm md:text-base font-body">17 bd des Évadés de France, Elne (66)</span>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={`${base}praticiens/`} size="lg" shadow="lg">
            Découvrir nos praticien·ne·s
            <Icon name="heroicons:chevron-right" class="w-5 h-5" />
          </Button>
          <a
            href={`${base}contact/`}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full border-2 border-sage-300 text-sage-700 font-body font-semibold hover:bg-sage-50 hover:border-sage-400 transition-all duration-300 hover:-translate-y-0.5"
          >
            Nous contacter
          </a>
        </div>

        <a href={`${base}salle/`} class="inline-flex items-center gap-1.5 mt-6 font-body text-sm text-warm-500 hover:text-terra-500 transition-colors">
          <Icon name="heroicons:building-office" class="w-3.5 h-3.5" />
          Une salle à louer pour vos activités
          <Icon name="heroicons:chevron-right" class="w-3.5 h-3.5" />
        </a>
      </div>

      <!-- Right: Hero Image with organic shape -->
      <div class="order-2 relative flex justify-center lg:justify-end py-8">
        <!-- Decorative ring behind image -->
        <div class="absolute top-2 right-2 w-[90%] h-[90%] rounded-[2rem] border-2 border-terra-200/50 rotate-3 hidden lg:block" aria-hidden="true"></div>
        <div class="absolute -bottom-3 -left-3 w-24 h-24 bg-sage-200/40 rounded-full blur-xl lg:block hidden" aria-hidden="true"></div>

        <!-- Image container with organic rounded shape -->
        <div class="relative w-full max-w-xs lg:max-w-sm">
          <div class="relative overflow-hidden hero-blob shadow-xl shadow-warm-300/30">
            <Image
              src={heroImg}
              alt="Ambiance chaleureuse de l'Espace Satya à Elne"
              width={600}
              height={680}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
              quality={80}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-warm-900/15 via-transparent to-sage-900/5" aria-hidden="true"></div>
          </div>

          <!-- Small floating accent badge -->
          <div class="absolute -bottom-2 -left-2 lg:-bottom-3 lg:-left-4 bg-white rounded-2xl shadow-lg shadow-warm-200/40 px-5 py-3 flex items-center gap-2 z-10">
            <div class="w-8 h-8 rounded-full bg-sage-100 flex items-center justify-center">
              <Icon name="heroicons:heart" class="w-4 h-4 text-sage-600" />
            </div>
            <span class="font-accent text-warm-700 text-lg">Bien-être holistique</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Transition wave -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none" aria-hidden="true">
    <svg class="relative block w-full h-12 md:h-16" viewBox="0 0 1200 60" preserveAspectRatio="none">
      <path d="M0 30 Q300 60 600 30 T1200 30 V60 H0 Z" fill="var(--color-warm-100)" />
      <path d="M0 30 Q300 60 600 30 T1200 30" fill="none" stroke="var(--color-terra-300)" stroke-width="1.5" opacity="0.5" />
    </svg>
  </div>
</section>

<style>
  .hero-blob {
    border-radius: 42% 58% 62% 38% / 45% 55% 45% 55%;
    aspect-ratio: 4 / 5;
  }
</style>
