---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  color?: 'sage' | 'terra';
  centered?: boolean;
  class?: string;
}

const { size = 'md', color = 'sage', centered = false, class: className = '' } = Astro.props;

const containerSizes: Record<string, string> = {
  sm: 'w-10 h-10',
  md: 'w-12 h-12',
  lg: 'w-14 h-14',
};

const bgColor = color === 'terra' ? 'bg-terra-100' : 'bg-sage-100';
---

<div class:list={[
  'rounded-full flex items-center justify-center shrink-0',
  containerSizes[size],
  bgColor,
  centered && 'mx-auto',
  className,
]}>
  <slot />
</div>
