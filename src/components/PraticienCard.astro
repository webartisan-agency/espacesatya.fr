---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from './Icon.astro';

interface Props {
  nom: string;
  titre: string;
  sousTitre?: string;
  slug: string;
  photo: ImageMetadata;
  photoAlt: string;
  accroche: string;
  specialites: string[];
  telephone?: string;
  email?: string;
  doctolib?: string;
  siteWeb?: string;
  nouveau?: boolean;
  variant?: 'compact' | 'full';
}

const {
  nom,
  titre,
  sousTitre,
  slug,
  photo,
  photoAlt,
  accroche,
  specialites,
  telephone,
  email,
  doctolib,
  siteWeb,
  nouveau = false,
  variant = 'compact',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const href = `${base}praticiens/${slug}/`;
---

<article
  class="group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 ease-out hover:-translate-y-1 border border-warm-200/60 cursor-pointer"
>
  <!-- Photo -->
  <div class="relative overflow-hidden bg-warm-100">
    <Image
      src={photo}
      alt={photoAlt}
      width={500}
      height={variant === 'full' ? 400 : 340}
      class:list={[
        'w-full object-cover object-top group-hover:scale-105 transition-transform duration-500 ease-out',
        variant === 'full' ? 'h-72' : 'h-60',
      ]}
      loading="lazy"
      decoding="async"
    />

    <!-- Overlay dégradé en bas -->
    <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-black/30 to-transparent"></div>

    <!-- Badge nouveau -->
    {nouveau && (
      <span class="absolute top-3 right-3 bg-terra-500 text-white text-xs font-body font-bold px-3 py-1 rounded-full shadow-md">
        Nouveau
      </span>
    )}
  </div>

  <!-- Contenu -->
  <div class="p-5">
    <!-- Nom et titre -->
    <div class="mb-3">
      {sousTitre && (
        <p class="font-accent text-terra-500 text-sm mb-1">{sousTitre}</p>
      )}
      <h3 class="font-heading text-warm-900 text-xl font-semibold group-hover:text-sage-700 transition-colors duration-200 leading-tight">
        {nom}
      </h3>
      <p class="font-body text-terra-600 text-sm font-medium mt-1 leading-snug">
        {titre}
      </p>
    </div>

    <!-- Accroche (version full) -->
    {variant === 'full' && (
      <p class="font-body text-warm-600 text-sm leading-relaxed mb-4 line-clamp-3">
        {accroche}
      </p>
    )}

    <!-- Spécialités -->
    <div class="flex flex-wrap gap-1.5 mt-3">
      {specialites.slice(0, 3).map((s) => (
        <span class="inline-block font-body text-xs font-medium px-2.5 py-1 rounded-full bg-sage-100 text-sage-700">
          {s}
        </span>
      ))}
    </div>

    <!-- Coordonnées -->
    {(telephone || email || doctolib || siteWeb) && (
      <div class="flex flex-wrap items-center gap-3 mt-4 pt-3 border-t border-warm-100">
        {telephone && (
          <a href={`tel:${telephone.replace(/\s/g, '')}`} class="relative z-10 inline-flex items-center gap-1 font-body text-xs text-warm-500 hover:text-sage-600 transition-colors">
            <Icon name="phone" class="w-3.5 h-3.5" strokeWidth={1.5} />
            {telephone}
          </a>
        )}
        {email && (
          <a href={`mailto:${email}`} class="relative z-10 inline-flex items-center gap-1 font-body text-xs text-warm-500 hover:text-sage-600 transition-colors">
            <Icon name="email" class="w-3.5 h-3.5" strokeWidth={1.5} />
            Email
          </a>
        )}
        {doctolib && (
          <a href={doctolib} target="_blank" rel="noopener noreferrer" class="relative z-10 inline-flex items-center gap-1 font-body text-xs font-medium text-sage-600 hover:text-sage-700 transition-colors">
            <Icon name="external-link" class="w-3.5 h-3.5" strokeWidth={1.5} />
            Doctolib
          </a>
        )}
        {siteWeb && !doctolib && (
          <a href={siteWeb} target="_blank" rel="noopener noreferrer" class="relative z-10 inline-flex items-center gap-1 font-body text-xs font-medium text-sage-600 hover:text-sage-700 transition-colors">
            <Icon name="external-link" class="w-3.5 h-3.5" strokeWidth={1.5} />
            Site web
          </a>
        )}
      </div>
    )}

    <!-- CTA flèche (stretched link, couvre toute la card) -->
    <div class="flex items-center justify-end mt-4">
      <a
        href={href}
        class="inline-flex items-center gap-1.5 font-body text-sm font-semibold text-sage-600 group-hover:text-sage-700 group-hover:gap-2.5 transition-all duration-200 after:absolute after:inset-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sage-400 focus-visible:ring-offset-2"
        aria-label={`Voir le profil de ${nom}, ${titre}`}
      >
        Découvrir
        <Icon name="chevron-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</article>
