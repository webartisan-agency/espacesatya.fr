---
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

interface Props {
  praticien: {
    nom: string;
    titre: string;
    sousTitre?: string;
    accroche: string;
    specialites: string[];
    photo: ImageMetadata;
    photoAlt: string;
    telephone?: string;
    email?: string;
    doctolib?: string;
    siteWeb?: string;
  };
  base: string;
}

const { praticien, base } = Astro.props;
---

<section class="bg-gradient-to-br from-warm-100 via-warm-50 to-sage-50 py-12 md:py-16 px-4 md:px-8">
  <div class="max-w-5xl mx-auto">
    <nav class="mb-8" aria-label="Fil d'Ariane">
      <ol class="flex items-center gap-2 font-body text-sm text-warm-500">
        <li><a href={base} class="hover:text-sage-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true">›</li>
        <li><a href={`${base}praticiens/`} class="hover:text-sage-600 transition-colors">Praticien·ne·s</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-warm-700 font-medium">{praticien.nom}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
      <!-- Photo -->
      <div class="relative">
        <div class="rounded-3xl overflow-hidden shadow-2xl">
          <Image
            src={praticien.photo}
            alt={praticien.photoAlt}
            width={700}
            height={800}
            class="w-full h-80 md:h-[500px] object-cover object-top"
            loading="eager"
            quality={85}
          />
        </div>
        <div class="absolute -bottom-4 -right-4 w-20 h-20 bg-sage-200 rounded-full -z-10" aria-hidden="true"></div>
        <div class="absolute -top-4 -left-4 w-12 h-12 bg-terra-100 rounded-full -z-10" aria-hidden="true"></div>
      </div>

      <!-- Infos -->
      <div>
        {praticien.sousTitre && (
          <p class="font-accent text-terra-500 text-xl mb-2">{praticien.sousTitre}</p>
        )}
        <h1 class="font-heading text-5xl md:text-6xl font-light text-warm-900 mb-2 leading-tight">
          {praticien.nom}
        </h1>
        <p class="font-body text-terra-600 font-medium text-lg mb-5">{praticien.titre}</p>
        <p class="font-body text-warm-600 leading-relaxed mb-6">{praticien.accroche}</p>

        <!-- Spécialités -->
        <div class="flex flex-wrap gap-2 mb-8">
          {praticien.specialites.map((s) => (
            <span class="inline-block font-body text-sm font-medium px-3 py-1.5 rounded-full bg-sage-100 text-sage-700 border border-sage-200">
              {s}
            </span>
          ))}
        </div>

        <!-- Contact -->
        <div class="flex flex-col gap-3">
          {praticien.telephone && (
            <a href={`tel:${praticien.telephone.replace(/\s/g, '')}`}
               class="inline-flex items-center gap-3 font-body text-warm-600 hover:text-sage-600 transition-colors">
              <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
                <Icon name="heroicons:phone" class="w-4 h-4 text-sage-600" />
              </span>
              {praticien.telephone}
            </a>
          )}
          {praticien.email && (
            <a href={`mailto:${praticien.email}`}
               class="inline-flex items-center gap-3 font-body text-warm-600 hover:text-sage-600 transition-colors">
              <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
                <Icon name="heroicons:envelope" class="w-4 h-4 text-sage-600" />
              </span>
              {praticien.email}
            </a>
          )}
          {praticien.siteWeb && (
            <a href={praticien.siteWeb} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-3 font-body text-warm-600 hover:text-sage-600 transition-colors">
              <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
                <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4 text-sage-600" />
              </span>
              Site web
            </a>
          )}
          {praticien.doctolib && (
            <a href={praticien.doctolib} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-terra-700 text-white font-body font-semibold px-6 py-3 rounded-full hover:bg-terra-800 transition-colors shadow-sm hover:shadow-md mt-2 w-fit">
              Prendre rendez-vous
              <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4" />
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
