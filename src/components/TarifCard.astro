---
interface Props {
  prestation: string;
  description?: string;
  prix?: string;
  duree?: string;
  note?: string;
  index?: number;
}

const { prestation, description, prix, duree, note, index = 0 } = Astro.props;
const dialogId = `tarif-dlg-${index}`;
const needsDialog = description && description.length > 80;
---

{needsDialog ? (
<button data-dialog-trigger={dialogId} class="bg-white rounded-2xl p-5 border border-warm-200 shadow-sm hover:shadow-md transition-shadow w-full cursor-pointer">
  <div class="flex items-start justify-between gap-3 text-left">
    <div class="min-w-0">
      <p class="font-body font-semibold text-warm-800">{prestation}</p>
      <p class="font-body text-sm text-warm-600 leading-relaxed line-clamp-2 mt-0.5">{description}</p>
      <span class="font-body text-xs text-terra-500 mt-1 inline-block">Lire la suite</span>
      {duree && <p class="font-body text-sm text-warm-500 mt-0.5">{duree}</p>}
      {note && <p class="font-body text-xs text-sage-600 mt-1">{note}</p>}
    </div>
    {prix ? (
      <span class="font-heading text-2xl font-semibold text-terra-500 shrink-0">{prix}</span>
    ) : (
      <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
        </svg>
      </span>
    )}
  </div>
</button>
<dialog id={dialogId} class="tarif-dialog">
  <button class="tarif-dialog-close" aria-label="Fermer">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
  <p class="font-body font-semibold text-warm-800 mb-2">{prestation}</p>
  <p class="font-body text-sm text-warm-600 leading-relaxed">{description}</p>
  {duree && <p class="font-body text-sm text-warm-500 mt-2">{duree}</p>}
  {note && <p class="font-body text-xs text-sage-600 mt-1">{note}</p>}
  {prix && <p class="font-heading text-xl font-semibold text-terra-500 mt-3">{prix}</p>}
</dialog>
) : (
<div class="bg-white rounded-2xl p-5 border border-warm-200 shadow-sm hover:shadow-md transition-shadow w-full">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="font-body font-semibold text-warm-800">{prestation}</p>
      {description && <p class="font-body text-sm text-warm-600 leading-relaxed mt-0.5">{description}</p>}
      {duree && <p class="font-body text-sm text-warm-500 mt-0.5">{duree}</p>}
      {note && <p class="font-body text-xs text-sage-600 mt-1">{note}</p>}
    </div>
    {prix ? (
      <span class="font-heading text-2xl font-semibold text-terra-500 shrink-0">{prix}</span>
    ) : (
      <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
        <svg class="w-4 h-4 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
        </svg>
      </span>
    )}
  </div>
</div>
)}

<style is:global>
  .tarif-dialog {
    max-width: 360px;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid var(--color-warm-200);
    box-shadow: 0 10px 25px -5px rgba(0,0,0,.1), 0 4px 10px -6px rgba(0,0,0,.1);
    background: white;
    margin: auto;
  }

  .tarif-dialog::backdrop {
    background: rgba(0,0,0,.25);
  }

  .tarif-dialog-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    color: var(--color-warm-400);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 50%;
    transition: color .2s;
  }

  .tarif-dialog-close:hover {
    color: var(--color-warm-700);
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('[data-dialog-trigger]') as HTMLElement | null;
    if (trigger) {
      const id = trigger.dataset.dialogTrigger;
      const dialog = id ? document.getElementById(id) as HTMLDialogElement | null : null;
      dialog?.showModal();
      return;
    }

    const closeBtn = (e.target as HTMLElement).closest('.tarif-dialog-close');
    if (closeBtn) {
      const dialog = closeBtn.closest('dialog') as HTMLDialogElement | null;
      dialog?.close();
    }
  });

  // Close on backdrop click
  document.querySelectorAll('.tarif-dialog').forEach(dialog => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        (dialog as HTMLDialogElement).close();
      }
    });
  });
</script>
