---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  mainClass?: string;
}

const {
  title,
  description = "Espace Satya, cabinet pluridisciplinaire de bien-être à Elne, Pyrénées-Orientales. Yoga, psychologie, sophrologie, hypnothérapie, massages, soins énergétiques et diététique.",
  image,
  mainClass,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Espace Satya`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {image && <meta property="og:image" content={image} />}

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Nunito+Sans:wght@300;400;600;700&family=Caveat:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Espace Satya</title>
  </head>
  <body class="min-h-screen flex flex-col bg-warm-50">
    <Header />
    <main class:list={[mainClass]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
