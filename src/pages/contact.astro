---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import SectionHeader from '../components/SectionHeader.astro';
import IconBadge from '../components/IconBadge.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contact & Accès"
  description="Contactez l'Espace Satya à Elne, 17 bd des Évadés de France, 1er étage Épicentre, 66200 Elne. Parking gratuit, 15 min de Perpignan."
>

    <!-- Header de page -->
    <section class="bg-gradient-to-br from-sage-100 to-warm-100 py-16 md:py-20 px-4 md:px-8">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          subtitle="Nous trouver"
          subtitleColor="sage"
          title="Contact & Accès"
          titleTag="h1"
          titleSize="5xl-6xl"
          description="Venez nous rendre visite à Elne, ou écrivez-nous pour toute question sur nos praticien·ne·s ou l'Espace Ananda."
          descriptionColor="warm-600"
          descriptionSize="lg"
          mb="0"
        />
      </div>
    </section>

    <!-- Contenu principal : infos + formulaire -->
    <section class="py-16 md:py-20 px-4 md:px-8 bg-warm-50">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

          <!-- Colonne gauche : infos pratiques -->
          <div>
            <h2 class="font-heading text-3xl font-light text-warm-900 mb-8">Informations pratiques</h2>

            <!-- Adresse -->
            <div class="mb-8 flex items-start gap-4">
              <IconBadge class="mt-1">
                <Icon name="location" class="w-6 h-6 text-sage-600" strokeWidth={1.5} />
              </IconBadge>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-1">Adresse</h3>
                <address class="not-italic font-body text-warm-600 leading-relaxed">
                  17 boulevard des Évadés de France<br />
                  1er étage, centre commercial Épicentre<br />
                  66200 Elne<br />
                  Pyrénées-Orientales (Occitanie)
                </address>
                <a
                  href="https://maps.google.com/?q=17+boulevard+des+Évadés+de+France+Elne+66200"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 mt-3 font-body text-sm font-medium text-sage-600 hover:text-sage-700 transition-colors"
                >
                  Ouvrir dans Google Maps
                  <Icon name="external-link" class="w-4 h-4" />
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="mb-8 flex items-start gap-4">
              <IconBadge class="mt-1">
                <Icon name="email" class="w-6 h-6 text-sage-600" strokeWidth={1.5} />
              </IconBadge>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-1">Email</h3>
                <a href="mailto:contact@espacesatya.fr" class="font-body text-warm-600 hover:text-sage-600 transition-colors">
                  contact@espacesatya.fr
                </a>
              </div>
            </div>

            <!-- Horaires -->
            <div class="mb-8 flex items-start gap-4">
              <IconBadge class="mt-1">
                <Icon name="clock" class="w-6 h-6 text-sage-600" strokeWidth={1.5} />
              </IconBadge>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-2">Horaires d'ouverture</h3>
                <dl class="font-body text-warm-600 space-y-1.5">
                  {[
                    { j: 'Lundi au samedi', h: 'Sur rendez-vous' },
                  ].map((slot) => (
                    <div class="flex gap-2">
                      <dt class="font-medium text-warm-700 min-w-[160px]">{slot.j}</dt>
                      <dd>{slot.h}</dd>
                    </div>
                  ))}
                </dl>
                <p class="font-body text-xs text-warm-500 mt-2">Les horaires varient selon les praticiennes. Contactez directement la praticienne souhaitée.</p>
              </div>
            </div>

            <!-- Accès -->
            <div class="flex items-start gap-4">
              <IconBadge class="mt-1">
                <Icon name="lightning" class="w-6 h-6 text-sage-600" strokeWidth={1.5} />
              </IconBadge>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-2">Comment venir</h3>
                <ul class="font-body text-warm-600 space-y-2">
                  <li class="flex items-center gap-2">
                    <Icon name="lightning" class="w-4 h-4 text-sage-500 shrink-0" strokeWidth={1.5} />
                    <span><strong class="text-warm-800">En voiture</strong> : parking gratuit du centre Épicentre, entrée principale</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <Icon name="location" class="w-4 h-4 text-sage-500 shrink-0" strokeWidth={1.5} />
                    <span><strong class="text-warm-800">En train</strong> : gare d'Elne à 10 min à pied</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <Icon name="chevron-right" class="w-4 h-4 text-sage-500 shrink-0" strokeWidth={1.5} />
                    <span><strong class="text-warm-800">Depuis Perpignan</strong> : 15 min (D900)</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <Icon name="sun" class="w-4 h-4 text-sage-500 shrink-0" strokeWidth={1.5} />
                    <span><strong class="text-warm-800">Depuis la côte</strong> : 10 min depuis Argelès-sur-Mer</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Colonne droite : contact direct -->
          <div>
            <h2 class="font-heading text-3xl font-light text-warm-900 mb-8">Nous écrire</h2>

            <div class="space-y-6">
              <div class="bg-sage-50 rounded-2xl p-6 border border-sage-200">
                <p class="font-body text-warm-600 leading-relaxed mb-5">
                  Pour toute question sur nos praticien·ne·s, pour prendre rendez-vous ou pour toute autre demande, 
                  envoyez-nous un email directement.
                </p>
                <Button
                  href="mailto:contact@espacesatya.fr?subject=Contact%20Espace%20Satya"
                  size="md"
                  shadow="sm"
                >
                  <Icon name="email" class="w-5 h-5" strokeWidth={1.5} />
                  Envoyer un email
                </Button>
              </div>

              <div class="bg-warm-100 rounded-2xl p-6 border border-warm-200">
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-2">Réserver l'Espace Ananda</h3>
                <p class="font-body text-warm-600 leading-relaxed text-sm mb-4">
                  Vous souhaitez louer la salle pour un cours, un atelier ou une formation ?
                </p>
                <a
                  href="mailto:contact@espacesatya.fr?subject=Demande%20de%20réservation%20Espace%20Ananda"
                  class="inline-flex items-center gap-2 font-body font-semibold text-sage-700 border-2 border-sage-600 px-5 py-2.5 rounded-full hover:bg-sage-700 hover:text-white transition-all duration-200"
                >
                  <Icon name="calendar" class="w-4 h-4" strokeWidth={1.5} />
                  Demander un créneau par email
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Carte Google Maps -->
    <section class="bg-warm-100" aria-label="Plan d'accès Espace Satya Elne">
      <iframe
        title="Localisation Espace Satya, Elne"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2892.5!2d2.9745!3d42.5997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12b07b3e9b3c3b7d%3A0x0!2s17+Boulevard+des+%C3%89vad%C3%A9s+de+France%2C+66200+Elne!5e0!3m2!1sfr!2sfr!4v1700000000000"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen={true}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="block"
      ></iframe>
    </section>

</BaseLayout>
