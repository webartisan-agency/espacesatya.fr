---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { Icon } from 'astro-icon/components';
import SectionHeader from '../components/SectionHeader.astro';
import InfoCard from '../components/InfoCard.astro';
import HomeHero from '../components/HomeHero.astro';
import CtaSection from '../components/CtaSection.astro';
import PraticienCard from '../components/PraticienCard.astro';
import { getActivePraticiens } from '../data/praticiens';
import { Image } from 'astro:assets';

import equipeImg from '../assets/photos/equipe.jpeg';

const praticiens = await getActivePraticiens();

const base = import.meta.env.BASE_URL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "name": "Espace Satya",
  "description": "Cabinet pluridisciplinaire de bien-être à Elne. Yoga, sophrologie, soins énergétiques, massages, hypnothérapie et diététique.",
  "url": "https://espacesatya.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "17 boulevard des Évadés de France",
    "addressLocality": "Elne",
    "postalCode": "66200",
    "addressCountry": "FR"
  },
  "hasMap": "https://maps.google.com/?q=Espace+Satya+Elne",
  "email": "contact@espacesatya.fr"
};

const valeurs = [
  { icon: 'heroicons:heart', titre: "Approche holistique", texte: "Nous considérons la personne dans sa globalité : corps, esprit, émotions, pour un accompagnement qui touche à la racine des choses." },
  { icon: 'heroicons:users', titre: "Pluridisciplinarité", texte: "Sept praticiennes aux expertises complémentaires, qui collaborent pour vous offrir un accompagnement coordonné et cohérent." },
  { icon: 'heroicons:sun', titre: "Bienveillance", texte: "Un espace sans jugement où chacun est accueilli tel qu'il est, avec sa singularité et son rythme propre." },
];
---

<BaseLayout
  title="Accueil"
  description="Espace Satya, cabinet pluridisciplinaire de bien-être à Elne. Yoga, psychologie, sophrologie, hypnothérapie, massages, soins énergétiques et diététique."
>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
    <HomeHero />

    <!-- ═══ PRÉSENTATION ══════════════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-4 md:px-8 bg-warm-100">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div>
            <p class="font-accent text-terra-500 text-xl mb-3">Notre cabinet</p>
            <h2 class="font-heading text-4xl md:text-5xl font-light text-warm-900 mb-6 leading-tight">
              L'Espace Satya,<br /><em class="not-italic text-sage-600">votre espace de soin</em>
            </h2>
            <div class="space-y-4 font-body text-warm-600 leading-relaxed">
              <p>Nichée au cœur d'Elne, dans les Pyrénées-Orientales, l'Espace Satya est un cabinet pluridisciplinaire réunissant sept praticiennes passionnées, chacune experte dans sa discipline.</p>
              <p>"Satya", la vérité en sanskrit, incarne notre philosophie : accompagner chaque personne avec authenticité, sans jugement, vers sa version la plus épanouie d'elle-même.</p>
              <p>Yoga, psychologie, sophrologie, hypnothérapie, massages, soins énergétiques, diététique… Des approches complémentaires qui dialoguent pour prendre soin de vous dans votre globalité.</p>
            </div>
            <a href={`${base}contact/`}
               class="inline-flex items-center gap-2 mt-8 font-body font-semibold text-sage-600 hover:text-sage-700 transition-colors">
              Venir nous voir
              <Icon name="heroicons:chevron-right" class="w-5 h-5" />
            </a>
          </div>
          <div class="relative">
            <div class="rounded-3xl overflow-hidden shadow-2xl">
              <Image src={equipeImg} alt="L'équipe de l'Espace Satya à Elne"
                     width={700} height={500} class="w-full h-auto object-cover" loading="lazy" />
            </div>
            <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-sage-100 rounded-full -z-10" aria-hidden="true"></div>
            <div class="absolute -top-4 -right-4 w-16 h-16 bg-terra-100 rounded-full -z-10" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ VALEURS ═══════════════════════════════════════════════════════ -->
    <section class="py-16 md:py-20 px-4 md:px-8 bg-warm-50">
      <div class="max-w-6xl mx-auto">
        <SectionHeader subtitle="Notre philosophie" subtitleColor="sage" title="Ce qui nous rassemble" titleSize="3xl-4xl" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {valeurs.map((v) => (
            <InfoCard icon={v.icon} title={v.titre} description={v.texte} size="lg" />
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ PRATICIENS ════════════════════════════════════════════════════ -->
    <section class="py-16 md:py-24 px-4 md:px-8 bg-warm-100">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          subtitle="Notre équipe"
          title="Nos praticien·ne·s"
          titleSize="4xl-5xl"
          description="Sept spécialistes du bien-être qui partagent une vision commune : vous accompagner avec bienveillance vers votre mieux-être."
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {praticiens.map((p) => {
            const { description, tarifs, ordre, actif, ...cardProps } = p.data;
            return (
              <PraticienCard {...cardProps} slug={p.id} variant="compact" />
            );
          })}
        </div>
        <div class="text-center mt-10">
          <a href={`${base}praticiens/`}
             class="inline-flex items-center gap-2 font-body font-semibold text-sage-700 border-2 border-sage-600 px-8 py-3 rounded-full hover:bg-sage-700 hover:text-white hover:border-sage-700 transition-all duration-300">
            Voir tous les profils
            <Icon name="heroicons:chevron-right" class="w-5 h-5" />
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ SALLE LOTUS ══════════════════════════════════════════════════ -->
    <CtaSection title="L'Espace Ananda" subtitle="Salle à louer" bgClass="bg-sage-700"
      description="38 m² climatisés au cœur d'un cabinet de bien-être."
    >
      <div slot="background" class="absolute inset-0 opacity-5" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.8) 1px, transparent 0); background-size: 32px 32px;"></div>
      </div>
      <p class="font-body text-sage-200 leading-relaxed mb-10 max-w-2xl mx-auto">
        Cours collectifs, ateliers, formations ou conférences : bénéficiez d'un cadre professionnel et d'une clientèle déjà sensibilisée au bien-être.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-10">
        {[
          { label: '38 m²', desc: 'Surface' },
          { label: '15 pers.', desc: 'Capacité' },
          { label: '15 €/h', desc: 'À partir de' },
          { label: 'Clim.', desc: 'Individuelle' },
        ].map((item) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-4 text-center min-w-[110px]">
            <p class="font-heading text-white text-2xl font-semibold">{item.label}</p>
            <p class="font-body text-sage-200 text-xs mt-1">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}salle/`}
           class="inline-flex items-center justify-center gap-2 bg-white text-sage-700 font-body font-semibold px-8 py-4 rounded-full hover:bg-warm-50 transition-all duration-300 shadow-lg hover:-translate-y-0.5">
          Découvrir la salle
          <Icon name="heroicons:chevron-right" class="w-5 h-5" />
        </a>
        <a href={`${base}contact/`}
           class="inline-flex items-center justify-center gap-2 bg-transparent text-white border-2 border-white/50 font-body font-semibold px-8 py-4 rounded-full hover:bg-white/10 transition-all duration-300">
          Demander un tarif
        </a>
      </div>
    </CtaSection>

    <!-- ═══ ACCÈS ══════════════════════════════════════════════════════════ -->
    <section class="py-16 px-4 md:px-8 bg-warm-100">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading text-3xl md:text-4xl font-light text-warm-900 mb-3">Venir nous voir</h2>
        <p class="font-body text-warm-600 mb-8">Facilement accessible depuis Perpignan et la côte méditerranéenne.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          {[
            { icon: 'heroicons:map-pin', title: 'Adresse', content: '17 bd des Évadés de France\n1er étage, Épicentre\n66200 Elne' },
            { icon: 'heroicons:clock', title: 'Horaires', content: 'Lundi au samedi\nsur rendez-vous' },
            { icon: 'heroicons:map', title: 'Accès', content: 'Parking gratuit\n15 min de Perpignan\n10 min d\'Argelès' },
          ].map((item) => (
            <InfoCard icon={item.icon} title={item.title} description={item.content} />
          ))}
        </div>
        <Button href={`${base}contact/`} size="lg">
          Voir le plan d'accès
          <Icon name="heroicons:chevron-right" class="w-5 h-5" />
        </Button>
      </div>
    </section>

</BaseLayout>
