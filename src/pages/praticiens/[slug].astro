---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const praticiens = await getCollection('praticiens');
  return praticiens.map((p) => ({
    params: { slug: p.id },
    props: { praticien: p },
  }));
}

const { praticien } = Astro.props;
const { Content } = await render(praticien);
const base = import.meta.env.BASE_URL;

// Navigation entre praticiens
const allPraticiens = await getCollection('praticiens', ({ data }) => data.actif);
allPraticiens.sort((a, b) => a.data.ordre - b.data.ordre);
const currentIdx = allPraticiens.findIndex((p) => p.id === praticien.id);
const prev = currentIdx > 0 ? allPraticiens[currentIdx - 1] : null;
const next = currentIdx < allPraticiens.length - 1 ? allPraticiens[currentIdx + 1] : null;
---

<BaseLayout
  title={`${praticien.data.nom} — ${praticien.data.titre}`}
  description={praticien.data.accroche}
>
  <Header />
  <main>

    <!-- Hero praticien -->
    <section class="bg-gradient-to-br from-warm-100 via-warm-50 to-sage-50 py-12 md:py-16 px-4 md:px-8">
      <div class="max-w-5xl mx-auto">
        <nav class="mb-8" aria-label="Fil d'Ariane">
          <ol class="flex items-center gap-2 font-body text-sm text-warm-400">
            <li><a href={base} class="hover:text-sage-600 transition-colors">Accueil</a></li>
            <li aria-hidden="true">›</li>
            <li><a href={`${base}praticiens/`} class="hover:text-sage-600 transition-colors">Praticien·ne·s</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-warm-700 font-medium">{praticien.data.nom}</li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
          <!-- Photo -->
          <div class="relative">
            <div class="rounded-3xl overflow-hidden shadow-2xl">
              <Image
                src={praticien.data.photo}
                alt={praticien.data.photoAlt}
                width={700}
                height={800}
                class="w-full h-80 md:h-[500px] object-cover object-top"
                loading="eager"
                quality={85}
              />
            </div>
            <div class="absolute -bottom-4 -right-4 w-20 h-20 bg-sage-200 rounded-full -z-10" aria-hidden="true"></div>
            <div class="absolute -top-4 -left-4 w-12 h-12 bg-terra-100 rounded-full -z-10" aria-hidden="true"></div>
          </div>

          <!-- Infos -->
          <div>
            {praticien.data.sousTitre && (
              <p class="font-accent text-terra-500 text-xl mb-2">{praticien.data.sousTitre}</p>
            )}
            <h1 class="font-heading text-5xl md:text-6xl font-light text-warm-900 mb-2 leading-tight">
              {praticien.data.nom}
            </h1>
            <p class="font-body text-terra-600 font-medium text-lg mb-5">{praticien.data.titre}</p>
            <p class="font-body text-warm-600 leading-relaxed mb-6">{praticien.data.accroche}</p>

            <!-- Spécialités -->
            <div class="flex flex-wrap gap-2 mb-8">
              {praticien.data.specialites.map((s) => (
                <span class="inline-block font-body text-sm font-medium px-3 py-1.5 rounded-full bg-sage-100 text-sage-700 border border-sage-200">
                  {s}
                </span>
              ))}
            </div>

            <!-- Contact -->
            <div class="flex flex-col gap-3">
              {praticien.data.telephone && (
                <a href={`tel:${praticien.data.telephone.replace(/\s/g, '')}`}
                   class="inline-flex items-center gap-3 font-body text-warm-600 hover:text-sage-600 transition-colors">
                  <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </span>
                  {praticien.data.telephone}
                </a>
              )}
              {praticien.data.email && (
                <a href={`mailto:${praticien.data.email}`}
                   class="inline-flex items-center gap-3 font-body text-warm-600 hover:text-sage-600 transition-colors">
                  <span class="w-9 h-9 bg-sage-100 rounded-full flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </span>
                  {praticien.data.email}
                </a>
              )}
              {praticien.data.doctolib && (
                <a href={praticien.data.doctolib} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-2 bg-terra-500 text-white font-body font-semibold px-6 py-3 rounded-full hover:bg-terra-600 transition-colors shadow-sm hover:shadow-md mt-2 w-fit">
                  Prendre rendez-vous
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contenu Markdown -->
    <section class="py-16 px-4 md:px-8 bg-warm-50">
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg max-w-none
          [&_h2]:font-heading [&_h2]:text-3xl [&_h2]:font-light [&_h2]:text-warm-900 [&_h2]:mb-4 [&_h2]:mt-10 [&_h2]:leading-tight
          [&_h3]:font-heading [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-warm-800 [&_h3]:mb-3 [&_h3]:mt-6
          [&_p]:font-body [&_p]:text-warm-600 [&_p]:leading-relaxed [&_p]:mb-4
          [&_ul]:font-body [&_ul]:text-warm-600 [&_ul]:space-y-2 [&_ul]:mb-4
          [&_li]:leading-relaxed [&_li]:pl-1
          [&_strong]:text-warm-800 [&_strong]:font-semibold
          [&_blockquote]:border-l-4 [&_blockquote]:border-sage-300 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-warm-500
          [&_a]:text-sage-600 [&_a]:hover:text-sage-700 [&_a:hover]:underline">
          <Content />
        </div>

        <!-- Tarifs si disponibles -->
        {praticien.data.tarifs && praticien.data.tarifs.length > 0 && (
          <div class="mt-12 pt-10 border-t border-warm-200">
            <h2 class="font-heading text-3xl font-light text-warm-900 mb-6">Tarifs</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {praticien.data.tarifs.map((t) => (
                <div class="bg-white rounded-2xl p-5 border border-warm-200 shadow-sm">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="font-body font-semibold text-warm-800">{t.prestation}</p>
                      {t.duree && <p class="font-body text-sm text-warm-400 mt-0.5">{t.duree}</p>}
                      {t.note && <p class="font-body text-xs text-sage-600 mt-1">{t.note}</p>}
                    </div>
                    <span class="font-heading text-2xl font-semibold text-terra-500 shrink-0">{t.prix}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- CTA contact -->
        <div class="mt-12 bg-sage-50 rounded-2xl p-8 border border-sage-200 text-center">
          <p class="font-heading text-2xl font-light text-warm-900 mb-2">Envie d'en savoir plus ?</p>
          <p class="font-body text-warm-500 mb-5">Contactez {praticien.data.nom} ou l'Espace Satya pour toute question.</p>
          <Button href={`${base}contact/`} size="md" shadow="sm">
            Nous contacter
          </Button>
        </div>
      </div>
    </section>

    <!-- Navigation praticiens -->
    <nav class="bg-warm-100 py-10 px-4 md:px-8" aria-label="Navigation entre les praticien·ne·s">
      <div class="max-w-5xl mx-auto flex items-center justify-between gap-4">
        {prev ? (
          <a href={`${base}praticiens/${prev.id}/`}
             class="flex items-center gap-3 group text-left max-w-[200px]">
            <span class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:bg-sage-100 transition-colors shrink-0">
              <svg class="w-5 h-5 text-warm-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            </span>
            <div>
              <p class="font-body text-xs text-warm-400">Précédent</p>
              <p class="font-heading text-warm-700 font-medium group-hover:text-sage-600 transition-colors">{prev.data.nom}</p>
            </div>
          </a>
        ) : <div />}

        <a href={`${base}praticiens/`}
           class="font-body text-sm text-warm-500 hover:text-sage-600 transition-colors hidden sm:block">
          Toutes les praticien·ne·s
        </a>

        {next ? (
          <a href={`${base}praticiens/${next.id}/`}
             class="flex items-center gap-3 group text-right max-w-[200px]">
            <div>
              <p class="font-body text-xs text-warm-400">Suivant·e</p>
              <p class="font-heading text-warm-700 font-medium group-hover:text-sage-600 transition-colors">{next.data.nom}</p>
            </div>
            <span class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:bg-sage-100 transition-colors shrink-0">
              <svg class="w-5 h-5 text-warm-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ) : <div />}
      </div>
    </nav>

  </main>
  <Footer />
</BaseLayout>
