---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../components/SectionHeader.astro';
import IconBadge from '../../components/IconBadge.astro';
import PraticienCard from '../../components/PraticienCard.astro';
import { getActivePraticiens } from '../../data/praticiens';

const praticiens = await getActivePraticiens();

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Nos praticien·ne·s"
  description="Découvrez les 7 praticiennes de l'Espace Satya à Elne : yoga, psychologie, sophrologie, hypnothérapie, massages, soins énergétiques et diététique."
>

    <!-- Header de page -->
    <section class="bg-gradient-to-br from-sage-100 to-warm-100 py-16 md:py-20 px-4 md:px-8">
      <div class="max-w-4xl mx-auto">
        <SectionHeader
          subtitle="L'équipe"
          subtitleColor="sage"
          title="Nos praticien·ne·s"
          titleTag="h1"
          titleSize="5xl-6xl"
          description="Sept spécialistes du bien-être, rassemblées dans un même espace pour vous accompagner avec expertise et bienveillance."
          descriptionColor="warm-600"
          descriptionSize="lg"
          descriptionMaxWidth="2xl"
          mb="0"
        />
      </div>
    </section>

    <!-- Grille praticiens -->
    <section class="py-16 md:py-20 px-4 md:px-8 bg-warm-50">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {praticiens.map((p) => {
            const { description, tarifs, ordre, actif, ...cardProps } = p.data;
            return (
              <PraticienCard {...cardProps} slug={p.id} variant="full" />
            );
          })}
        </div>
      </div>
    </section>

    <!-- Encart Duo Pauline + Cloé -->
    <section class="py-12 px-4 md:px-8 bg-terra-50">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-sm border-l-4 border-terra-400">
          <div class="flex items-start gap-4">
            <IconBadge color="terra" class="mt-1">
              <Icon name="heroicons:star" class="w-6 h-6 text-terra-500" />
            </IconBadge>
            <div>
              <p class="font-body text-terra-600 text-sm font-semibold uppercase tracking-wide mb-2">Collaboration unique</p>
              <h2 class="font-heading text-2xl md:text-3xl font-semibold text-warm-900 mb-3">
                Duo Pauline + Cloé
              </h2>
              <p class="font-body text-warm-600 leading-relaxed mb-4">
                Pour les troubles alimentaires chez les enfants, adolescents et jeunes adultes, Pauline (psychothérapeute) et Cloé (diététicienne) travaillent en binôme. Une prise en charge coordonnée qui associe le soin psychologique et l'accompagnement nutritionnel pour une approche vraiment complète.
              </p>
              <a
                href={`${base}contact/`}
                class="inline-flex items-center gap-2 font-body text-sm font-semibold text-terra-600 hover:text-terra-700 transition-colors"
              >
                En savoir plus
                <Icon name="heroicons:chevron-right" class="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

</BaseLayout>
